---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection';
import CategoryGrid from '../components/CategoryGrid';
import FeaturedProducts from '../components/FeaturedProducts';
import NewsletterBanner from '../components/NewsletterBanner';
import { getAllProductos, getProductosConDescuento } from '../data/productos';

const allProducts = getAllProductos();
const saleProducts = getProductosConDescuento();
// Feature a curated selection (first 4 products)
const featured = allProducts.slice(0, 4);
---

<Layout
  title="Online Music Shop — Guitarras, Pedales y Amplificadores"
  description="Tu tienda online de instrumentos musicales. Guitarras, pedales de efectos y amplificadores de las mejores marcas internacionales."
>
  <!-- Hero -->
  <HeroSection client:load />

  <!-- Category Grid -->
  <CategoryGrid client:visible />

  <!-- Sale products (if any) -->
  {saleProducts.length > 0 && (
    <section class="py-16" style="background: linear-gradient(180deg, #fff 0%, #F4F4F5 100%);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-6">
        <div class="flex items-center gap-3">
          <span class="bg-brand-yellow text-neutral-dark font-heading font-bold text-sm px-3 py-1.5 rounded-full uppercase tracking-wide animate-pulse-soft">
            🔥 Oferta Activa
          </span>
          <div class="h-px flex-1 bg-ui-100" />
        </div>
      </div>
      <FeaturedProducts
        client:visible
        title="Productos en Oferta"
        subtitle="Aprovecha los descuentos de temporada"
        productos={saleProducts}
        showViewAll={false}
      />
    </section>
  )}

  <!-- Featured Products -->
  <FeaturedProducts
    client:visible
    title="Productos Destacados"
    subtitle="Selección especial para músicos exigentes"
    productos={featured}
    showViewAll={true}
    viewAllHref="/categorias"
  />

  <!-- Brand Logos Strip -->
  <section class="py-12 border-y border-ui-100 overflow-hidden bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs text-ui-400 uppercase tracking-widest font-semibold mb-8">Nuestras Marcas</p>
      <div class="flex flex-wrap items-center justify-center gap-10 md:gap-14">
        {[
          { nombre: 'Tagima', logo: '/brands/tagima.png', href: '/categorias?marca=Tagima', h: 'h-14' },
          { nombre: 'Schecter', logo: '/brands/schecter.png', href: '/categorias?marca=Schecter', h: 'h-12' },
          { nombre: 'Valeton', logo: '/brands/valeton.png', href: '/categorias?marca=Valeton', h: 'h-8' },
          { nombre: 'Hotone', logo: '/brands/hotone.png', href: '/categorias?marca=Hotone', h: 'h-10' },
          { nombre: 'Sonicake', logo: '/brands/sonicake.png', href: '/categorias?marca=Sonicake', h: 'h-12' },
          { nombre: 'Nux', logo: '/brands/nux.png', href: '/categorias?marca=Nux', h: 'h-8' },
        ].map(brand => (
          <a
            href={brand.href}
            title={brand.nombre}
            class="grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-300 hover:scale-110"
          >
            <img
              src={brand.logo}
              alt={brand.nombre}
              class={`${brand.h} w-auto object-contain`}
              loading="lazy"
            />
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/categorias" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-orange hover:underline">
          Ver todos los productos
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Features strip -->
  <section class="py-10 bg-ui-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { icon: '🚚', title: 'Envío Gratis', desc: 'En pedidos +$25' },
          { icon: '🔒', title: 'Compra Segura', desc: 'Pagos protegidos' },
          { icon: '⭐', title: 'Puntos de Lealtad', desc: '1 punto por $1 gastado' },
          { icon: '🎸', title: 'Expertos en Música', desc: 'Asesoría personalizada' },
        ].map(f => (
          <div class="text-center p-4">
            <div class="text-3xl mb-2">{f.icon}</div>
            <h3 class="font-heading text-sm text-neutral-dark uppercase">{f.title}</h3>
            <p class="text-xs text-ui-400 mt-0.5">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <NewsletterBanner client:visible />
</Layout>
