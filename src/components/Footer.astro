---
---
<footer style="background-color: #1A1A1A;" class="text-white pt-4 sm:pt-14 pb-6">
  <div class="w-full px-6 sm:px-10 lg:px-16 xl:px-24">

    <!-- Main grid — hidden on mobile, visible from sm up -->
    <div class="hidden sm:grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-6 gap-10 lg:gap-16 pb-12 border-b border-white/10">

      <!-- Brand col -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-block mb-5">
          <img src="/logo.png" alt="Online Music Shop" class="h-20 w-auto" />
        </a>
        <p class="text-white/55 text-sm leading-relaxed mb-5">
          Somos una empresa en línea innovadora dedicada al comercio de instrumentos y accesorios musicales de prestigiosas marcas en la industria, ofreciendo la mejor calidad a nuestros músicos con el fin de hacer crecer el talento y el amor por la música.
        </p>
        <div class="flex gap-5">
          <a href="#" class="text-white/60 hover:text-white transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/online_music_shopsv" target="_blank" rel="noopener noreferrer" class="text-white/60 hover:text-white transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="text-white/60 hover:text-white transition-colors" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>
          </a>
          <a href="#" class="text-white/60 hover:text-white transition-colors" aria-label="TikTok">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.17 8.17 0 004.79 1.52V6.76a4.85 4.85 0 01-1.02-.07z"/></svg>
          </a>
        </div>
      </div>

      <!-- Categorías -->
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-5">Categorías</h4>
          <ul class="space-y-3.5">
          <li><a href="/categorias/guitarras" class="text-white/60 hover:text-white text-sm transition-colors">Guitarras Eléctricas</a></li>
          <li><a href="/categorias/pedales" class="text-white/60 hover:text-white text-sm transition-colors">Pedales y Multiefectos</a></li>
          <li><a href="/categorias/amplificadores" class="text-white/60 hover:text-white text-sm transition-colors">Amplificadores</a></li>
          <li><a href="/categorias/estuches" class="text-white/60 hover:text-white text-sm transition-colors">Estuches y Bolsos</a></li>
          <li><a href="/categorias" class="text-white/60 hover:text-white text-sm transition-colors">Ver todo el catálogo</a></li>
        </ul>
      </div>

      <!-- Servicio al cliente -->
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-5">Servicio al Cliente</h4>
        <ul class="space-y-3.5">
          <li><a href="/nosotros" class="text-white/60 hover:text-white text-sm transition-colors">Sobre Nosotros</a></li>
          <li><a href="/cuenta" class="text-white/60 hover:text-white text-sm transition-colors">Programa de Lealtad</a></li>
          <li><a href="/login" class="text-white/60 hover:text-white text-sm transition-colors">Mi Cuenta</a></li>
          <li><a href="/checkout" class="text-white/60 hover:text-white text-sm transition-colors">Finalizar Compra</a></li>
          <li><a href="#" class="text-white/60 hover:text-white text-sm transition-colors">Política de Envíos</a></li>
          <li><a href="#" class="text-white/60 hover:text-white text-sm transition-colors">Devoluciones</a></li>
        </ul>
      </div>

      <!-- Información -->
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-5">Información</h4>
        <ul class="space-y-3.5">
          <li><a href="#" class="text-white/60 hover:text-white text-sm transition-colors">Términos y Condiciones</a></li>
          <li><a href="#" class="text-white/60 hover:text-white text-sm transition-colors">Política de Privacidad</a></li>
          <li><a href="#" class="text-white/60 hover:text-white text-sm transition-colors">Cookies</a></li>
          <li><a href="#" class="text-white/60 hover:text-white text-sm transition-colors">Preguntas Frecuentes</a></li>
          <li><a href="#" class="text-white/60 hover:text-white text-sm transition-colors">Asesoría de Compra</a></li>
        </ul>
      </div>

      <!-- Contacto y horarios -->
      <div>
        <h4 class="text-sm font-bold text-white uppercase tracking-widest mb-5">Visítanos</h4>
        <div class="space-y-3 text-sm text-white/60">
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div>
              <p class="text-white/80 font-medium">Hillside Mall</p>
              <p>C. La Mascota 520, San Salvador</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:25253357" class="hover:text-brand-orange transition-colors">2525 3357</a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@onlinemusicshop.sv" class="hover:text-brand-orange transition-colors">info@onlinemusicshop.sv</a>
          </div>

          <!-- Hours -->
          <div class="mt-4 pt-4 border-t border-white/10 space-y-1 text-xs">
            <p class="text-white/80 font-semibold text-sm mb-2">Horario Showroom</p>
            <div class="flex justify-between">
              <span>Lunes – Viernes</span><span class="text-white/80">9:30 AM – 5:30 PM</span>
            </div>
            <div class="flex justify-between">
              <span>Sábado</span><span class="text-white/80">9:30 AM – 4:00 PM</span>
            </div>
            <div class="flex justify-between">
              <span>Domingo</span><span class="text-red-400">Cerrado</span>
            </div>
          </div>

          <!-- Payment methods -->
          <div class="mt-4 pt-4 border-t border-white/10">
            <p class="text-white/40 text-xs mb-3">Aceptamos las siguientes tarjetas</p>
            <div class="flex gap-3 items-center">
              <img src="/visa.png" alt="Visa" class="h-6 w-auto object-contain opacity-80" />
              <img src="/mc.png" alt="Mastercard" class="h-7 w-auto object-contain opacity-80" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-4 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/30">
      <div class="hidden sm:flex flex-wrap gap-5">
        <a href="#" class="hover:text-white/60 transition-colors">Términos de Uso</a>
        <a href="#" class="hover:text-white/60 transition-colors">Privacidad</a>
        <a href="#" class="hover:text-white/60 transition-colors">Cookies</a>
        <a href="#" class="hover:text-white/60 transition-colors">Accesibilidad</a>
      </div>
      <p class="text-center sm:text-right">© 2026 Online Music Shop. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

